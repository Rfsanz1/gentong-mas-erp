datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== AUTH & USERS ====================

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  password  String
  active    Boolean    @default(true)
  roleId    String
  role      Role       @relation(fields: [roleId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  orders    Order[]
  auditLogs AuditLog[]
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  @@id([roleId, permissionId])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  action      String
  resource    String
  metadata    Json?
  tableName   String?
  recordId    String?
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  branchId    String?
  createdAt   DateTime @default(now())
}

// ==================== MASTER DATA ====================

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DriverArea {
  id        Int      @id @default(autoincrement())
  name      String
  areas     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== INVENTORY ENUMS ====================

enum CostingMethod {
  FIFO
  AVERAGE
  STANDARD
}

enum LandedCostSplitMethod {
  BY_QTY
  BY_VALUE
  BY_WEIGHT
}

// ==================== WAREHOUSE ====================
// Central warehouse entity. Products are linked to warehouses
// via the Stock model (many-to-many through Stock).

model Warehouse {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  address        String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stocks         Stock[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
}

model ProductCategory {
  id        String            @id @default(uuid())
  code      String            @unique
  name      String
  parentId  String?
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model ProductUnit {
  id        String    @id @default(uuid())
  name      String    @unique
  symbol    String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ==================== PRODUCT ====================
// Products do NOT hold stock qty directly.
// Stock is tracked per-warehouse via the Stock model.
// All stock changes flow through StockMovement.

model Product {
  id                 String              @id @default(uuid())
  sku                String              @unique
  name               String
  brand              String?
  categoryId         String?
  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  unitId             String?
  unit               ProductUnit?        @relation(fields: [unitId], references: [id])
  hargaBeli          Decimal             @default(0) @db.Decimal(15, 2)
  hargaJual          Decimal             @default(0) @db.Decimal(15, 2)
  hargaKledo         Decimal             @default(0) @db.Decimal(15, 2)
  stokMinimum        Int                 @default(0)
  costingMethod      CostingMethod       @default(AVERAGE)
  standardCost       Decimal             @default(0) @db.Decimal(15, 4)
  currentAvgCost     Decimal             @default(0) @db.Decimal(15, 4)
  kledoProductId     String?
  isSpmBrand         Boolean             @default(false)
  active             Boolean             @default(true)
  description        String?
  imageUrl           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  // Stock tracking (one product can exist in multiple warehouses)
  stocks             Stock[]
  orderItems         OrderItem[]
  saleItems          SaleItem[]
  stockMovements     StockMovement[]
  stockOpnameItems   StockOpnameItem[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  posProducts        PosProduct[]
  stockValuations    StockValuation[]
  stockLots          StockLot[]
  landedCostItems    LandedCostItem[]
}

// ==================== STOCK ====================
// Per-warehouse stock quantity for each product.
// This is the single source of truth for available stock.
// RULE: qty is only updated via updateStok() which always
//       creates a matching StockMovement entry first.

model Stock {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  qty         Decimal   @default(0) @db.Decimal(15, 4)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@unique([productId, warehouseId])
}

// ==================== STOCK MOVEMENT ====================
// Immutable audit trail of all stock changes.
// Every stock IN / OUT must produce a StockMovement record.

model StockMovement {
  id          String     @id @default(uuid())
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  type        String
  qty         Decimal   @db.Decimal(15,4)
  note        String?
  referenceId String?
  createdAt   DateTime   @default(now())
}

model StockValuation {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  date         DateTime
  qty          Decimal  @db.Decimal(15, 4)
  unitCost     Decimal  @db.Decimal(15, 4)
  totalValue   Decimal  @db.Decimal(15, 2)
  movementType String
  referenceId  String?
  createdAt    DateTime @default(now())
}

model StockLot {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  nomorLot    String
  expiryDate  DateTime?
  qtyAwal     Decimal   @db.Decimal(15, 4)
  qtySisa     Decimal   @db.Decimal(15, 4)
  unitCost    Decimal   @db.Decimal(15, 4)
  referenceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@unique([productId, nomorLot])
}

model LandedCost {
  id          String                @id @default(uuid())
  purchaseId  String
  deskripsi   String
  amount      Decimal               @db.Decimal(15, 2)
  splitMethod LandedCostSplitMethod
  status      String                @default("draft")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  items       LandedCostItem[]
}

model LandedCostItem {
  id           String     @id @default(uuid())
  landedCostId String
  landedCost   LandedCost @relation(fields: [landedCostId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  qty          Decimal    @db.Decimal(15, 4)
  alokasiBiaya Decimal    @db.Decimal(15, 2)
  createdAt    DateTime   @default(now())
}

model StockOpname {
  id          String            @id @default(uuid())
  date        DateTime
  warehouseId String?
  status      String            @default("draft")
  note        String?
  items       StockOpnameItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model StockOpnameItem {
  id            String      @id @default(uuid())
  stockOpnameId String
  stockOpname   StockOpname @relation(fields: [stockOpnameId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  stokSistem    Int
  stokFisik     Int
  selisih       Int
  note          String?
}

// ==================== CUSTOMERS & SUPPLIERS ====================

model Customer {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  province    String?
  npwp        String?
  kledoId     String?  @unique
  creditLimit Decimal  @default(0) @db.Decimal(15, 2)
  creditUsed  Decimal  @default(0) @db.Decimal(15, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  sales       Sale[]
}

model Supplier {
  id             String                @id @default(uuid())
  code           String                @unique
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  npwp           String?
  bankName       String?
  bankAccount    String?
  active         Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  purchaseOrders PurchaseOrder[]
  rfqs           RequestForQuotation[]
  pricelist      VendorPricelist[]
}

// ==================== SALES & ORDERS ====================

model Order {
  id               Int       @id @default(autoincrement())
  namaCustomer     String
  noHp             String?
  alamat           String?
  catatan          String?
  salesName        String?
  userId           String?
  user             User?     @relation(fields: [userId], references: [id])
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  totalHarga       Decimal   @default(0) @db.Decimal(15, 2)
  status           String    @default("pending")
  statusPengiriman String?
  driverName       String?
  fotoPengiriman   String?
  lokasiToken      String?
  lokasiLat        String?
  lokasiLng        String?
  lokasiUpdatedAt  DateTime?
  kledoInvoiceId   String?   @unique
  kledoSynced      Boolean   @default(false)
  buktiTransferData String?
  items            Json      @default("[]")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  orderItems       OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  nama      String
  qty       Int
  harga     Decimal  @db.Decimal(15, 2)
  subtotal  Decimal  @db.Decimal(15, 2)
}

model Sale {
  id         String     @id @default(uuid())
  noFaktur   String     @unique
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  salesName  String?
  tanggal    DateTime
  totalHarga Decimal    @default(0) @db.Decimal(15, 2)
  diskon     Decimal    @default(0) @db.Decimal(15, 2)
  pajak      Decimal    @default(0) @db.Decimal(15, 2)
  grandTotal Decimal    @default(0) @db.Decimal(15, 2)
  status     String     @default("draft")
  kledoId    String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      SaleItem[]
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  nama      String
  qty       Int
  harga     Decimal  @db.Decimal(15, 2)
  subtotal  Decimal  @db.Decimal(15, 2)
}

// ==================== PURCHASING ====================

model PurchaseOrder {
  id            String              @id @default(uuid())
  noPo          String              @unique
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  warehouseId   String?
  warehouse     Warehouse?          @relation(fields: [warehouseId], references: [id])
  tanggal       DateTime
  tanggalKirim  DateTime?
  totalHarga    Decimal             @default(0) @db.Decimal(15, 2)
  status        String              @default("draft")
  note          String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  items         PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id])
  nama            String
  qty             Int
  hargaBeli       Decimal       @db.Decimal(15, 2)
  subtotal        Decimal       @db.Decimal(15, 2)
  qtyReceived     Int           @default(0)
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  noGr            String             @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  tanggal         DateTime
  status          String             @default("draft")
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  items           GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id             String       @id @default(uuid())
  goodsReceiptId String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  productId      String?
  product        Product?     @relation(fields: [productId], references: [id])
  nama           String
  qtyOrdered     Int
  qtyReceived    Int
}

// ==================== FINANCE & ACCOUNTING ====================

model ChartOfAccount {
  id               String             @id @default(uuid())
  code             String             @unique
  name             String
  type             String
  parentId         String?
  parent           ChartOfAccount?    @relation("CoaTree", fields: [parentId], references: [id])
  children         ChartOfAccount[]   @relation("CoaTree")
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  journalLines     JournalEntryLine[]
  bankTransactions BankTransaction[]
  cashTransactions CashTransaction[]
}

model JournalEntry {
  id          String             @id @default(uuid())
  noJurnal    String             @unique
  tanggal     DateTime
  keterangan  String?
  referenceId String?
  type        String
  total       Decimal            @default(0) @db.Decimal(15, 2)
  status      String             @default("draft")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  lines       JournalEntryLine[]
}

model JournalEntryLine {
  id             String         @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id])
  coaId          String
  coa            ChartOfAccount @relation(fields: [coaId], references: [id])
  debit          Decimal        @default(0) @db.Decimal(15, 2)
  kredit         Decimal        @default(0) @db.Decimal(15, 2)
  keterangan     String?
}

model BankAccount {
  id           String            @id @default(uuid())
  bankName     String
  accountNo    String
  accountName  String
  balance      Decimal           @default(0) @db.Decimal(15, 2)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  transactions BankTransaction[]
}

model BankTransaction {
  id            String          @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id])
  coaId         String?
  coa           ChartOfAccount? @relation(fields: [coaId], references: [id])
  tanggal       DateTime
  type          String
  amount        Decimal         @db.Decimal(15, 2)
  keterangan    String?
  referenceId   String?
  createdAt     DateTime        @default(now())
}

model CashTransaction {
  id          String          @id @default(uuid())
  coaId       String?
  coa         ChartOfAccount? @relation(fields: [coaId], references: [id])
  tanggal     DateTime
  type        String
  amount      Decimal         @db.Decimal(15, 2)
  keterangan  String?
  referenceId String?
  createdAt   DateTime        @default(now())
}

// ==================== HR & PAYROLL ====================

model Employee {
  id               String            @id @default(uuid())
  nik              String            @unique
  name             String
  email            String?
  phone            String?
  address          String?
  departemen       String?
  jabatan          String?
  tanggalMasuk     DateTime?
  gapok            Decimal           @default(0) @db.Decimal(15, 2)
  ptkpStatus       String            @default("TK/0")
  status           String            @default("aktif")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  payrolls         Payroll[]
  attendances      Attendance[]
  leaveAllocations LeaveAllocation[]
  leaveRequests    LeaveRequest[]
  payrollSlips     PayrollSlip[]
  bpjsConfig       BPJSConfig?
}

model Payroll {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  periode    String
  gapok      Decimal  @default(0) @db.Decimal(15, 2)
  tunjangan  Decimal  @default(0) @db.Decimal(15, 2)
  potongan   Decimal  @default(0) @db.Decimal(15, 2)
  netto      Decimal  @default(0) @db.Decimal(15, 2)
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Attendance {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  tanggal    DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     String    @default("hadir")
  note       String?
  createdAt  DateTime  @default(now())
}

// ==================== INTEGRATIONS ====================

model KledoSyncLog {
  id        String   @id @default(uuid())
  type      String
  status    String
  message   String?
  payload   Json?
  response  Json?
  createdAt DateTime @default(now())
}

model ShopeeOrder {
  id            String   @id @default(uuid())
  shopeeOrderId String   @unique
  buyerName     String?
  phone         String?
  address       String?
  items         Json     @default("[]")
  totalHarga    Decimal  @default(0) @db.Decimal(15, 2)
  status        String   @default("pending")
  rawData       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String    @id @default(uuid())
  recipient String
  title     String
  message   String
  status    String    @default("pending")
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

// ==================== POS ====================

model PosUser {
  id        String              @id @default(uuid())
  username  String              @unique
  password  String
  name      String
  role      String              @default("kasir")
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  sessions  PosCashierSession[]
  sales     PosSale[]
}

model PosCashierSession {
  id         String    @id @default(uuid())
  posUserId  String
  posUser    PosUser   @relation(fields: [posUserId], references: [id])
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  modalAwal  Decimal   @default(0) @db.Decimal(15, 2)
  modalAkhir Decimal?  @db.Decimal(15, 2)
  status     String    @default("open")
  sales      PosSale[]
}

model PosCategory {
  id        String       @id @default(uuid())
  name      String
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  products  PosProduct[]
}

model PosProduct {
  id         String        @id @default(uuid())
  productId  String?
  product    Product?      @relation(fields: [productId], references: [id])
  categoryId String?
  category   PosCategory?  @relation(fields: [categoryId], references: [id])
  name       String
  barcode    String?       @unique
  hargaJual  Decimal       @db.Decimal(15, 2)
  stok       Int           @default(0)
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  saleItems  PosSaleItem[]
}

model PosSale {
  id          String             @id @default(uuid())
  noStruk     String             @unique
  sessionId   String?
  session     PosCashierSession? @relation(fields: [sessionId], references: [id])
  posUserId   String?
  posUser     PosUser?           @relation(fields: [posUserId], references: [id])
  tanggal     DateTime           @default(now())
  totalHarga  Decimal            @default(0) @db.Decimal(15, 2)
  diskon      Decimal            @default(0) @db.Decimal(15, 2)
  pajak       Decimal            @default(0) @db.Decimal(15, 2)
  grandTotal  Decimal            @default(0) @db.Decimal(15, 2)
  bayar       Decimal            @default(0) @db.Decimal(15, 2)
  kembalian   Decimal            @default(0) @db.Decimal(15, 2)
  metodeBayar String             @default("tunai")
  status      String             @default("selesai")
  createdAt   DateTime           @default(now())
  items       PosSaleItem[]
}

model PosSaleItem {
  id           String     @id @default(uuid())
  saleId       String
  sale         PosSale    @relation(fields: [saleId], references: [id])
  posProductId String
  posProduct   PosProduct @relation(fields: [posProductId], references: [id])
  nama         String
  qty          Int
  harga        Decimal    @db.Decimal(15, 2)
  subtotal     Decimal    @db.Decimal(15, 2)
}

// ==================== CRM ====================

model Lead {
  id              String        @id @default(uuid())
  name            String
  type            String        @default("lead")
  stage           String        @default("new")
  priority        Int           @default(0)
  probability     Decimal       @default(0) @db.Decimal(5, 2)
  expectedRevenue Decimal       @default(0) @db.Decimal(15, 2)
  customerId      String?
  salespersonId   String?
  teamId          String?
  team            SalesTeam?    @relation(fields: [teamId], references: [id])
  phone           String?
  email           String?
  company         String?
  source          String?
  description     String?
  closingDate     DateTime?
  active             Boolean             @default(true)
  lostReason      String?
  status          String        @default("open")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activities      CrmActivity[]
}

model SalesTeam {
  id        String   @id @default(uuid())
  name      String   @unique
  leaderId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  leads     Lead[]
}

model CrmActivity {
  id          String    @id @default(uuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id])
  type        String
  status      String    @default("planned")
  doneDate    DateTime?
  summary     String
  dueDate     DateTime?
  completedAt DateTime?
  userId      String?
  createdAt   DateTime  @default(now())
}

// ==================== PROJECT ====================

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      String        @default("planning")
  startDate   DateTime?
  dueDate     DateTime?
  managerId   String?
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tasks       Task[]
  milestones  Milestone[]
  timesheets  Timesheet[]
}


model Milestone {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  dueDate   DateTime
  isDone    Boolean  @default(false)
  tasks     Task[]
  createdAt DateTime @default(now())
}

model Timesheet {
  id          String   @id @default(uuid())
  projectId   String
  taskId      String?
  task        Task?     @relation(fields: [taskId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
  employeeId  String?
  date        DateTime
  hours       Decimal  @db.Decimal(5, 2)
  description String?
  createdAt   DateTime @default(now())
}

// ==================== HELPDESK ====================

model HelpdeskTicket {
  id          String    @id @default(uuid())
  noTicket    String    @unique
  subject     String
  description String?
  customerId  String?
  assigneeId  String?
  priority    Int       @default(0)
  stage       String    @default("new")
  rating      Int?
  ratingComment String?
  closedAt    DateTime?
  teamId      String?
  team        HelpdeskTeam? @relation(fields: [teamId], references: [id])
  slaDeadline DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== MANUFACTURING ====================

model BillOfMaterial {
  id          String        @id @default(uuid())
  productId   String
  qty         Decimal       @db.Decimal(15, 4)
  type        String        @default("manufacture")
