model ManufacturingOrder {
  id        String         @id @default(uuid())
  noMo      String         @unique
  bomId     String
  bom       BillOfMaterial @relation(fields: [bomId], references: [id])
  qtyToProduce Decimal     @db.Decimal(15, 4)
