// ==================== TAX ENGINE ====================

enum TaxType {
  PPN
  PPH21
  PPH23
  PPH25
  PPH4A2
}

enum TaxLineType {
  COLLECTED
  PAID
}

enum EFakturStatus {
  DRAFT
  UPLOADED
  APPROVED
}

model Tax {
  id        String    @id @default(uuid())
  kode      String    @unique
  nama      String
  tipe      TaxType
  rate      Decimal   @db.Decimal(5, 2)
  isActive  Boolean   @default(true)
  accountId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  taxLines  TaxLine[]
  efakturs  EFaktur[]
}

model TaxLine {
  id            String      @id @default(uuid())
  referenceId   String
  referenceType String
  taxId         String
  tax           Tax         @relation(fields: [taxId], references: [id])
  baseAmount    Decimal     @db.Decimal(15, 2)
  taxAmount     Decimal     @db.Decimal(15, 2)
  tipe          TaxLineType
  createdAt     DateTime    @default(now())
}

model EFaktur {
  id            String        @id @default(uuid())
  nomorFaktur   String        @unique
  tanggal       DateTime
  taxId         String?
  tax           Tax?          @relation(fields: [taxId], references: [id])
  referenceId   String?
  npwpPembeli   String?
  namaPembeli   String?
  nilaiDPP      Decimal       @db.Decimal(15, 2)
  nilaiPPN      Decimal       @db.Decimal(15, 2)
  status        EFakturStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ==================== DOUBLE-ENTRY ACCOUNTING ====================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum FiscalStatus {
  OPEN
  CLOSED
}

model Account {
  id            String      @id @default(uuid())
  code          String      @unique
  name          String
  type          AccountType
  parentId      String?
  parent        Account?    @relation("AccountTree", fields: [parentId], references: [id])
  children      Account[]   @relation("AccountTree")
  description   String?
  isActive      Boolean     @default(true)
  normalBalance String      @default("DEBIT")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  journalLines  JournalLine[]
}

model Journal {
  id          String        @id @default(uuid())
  nomor       String        @unique
  tanggal     DateTime
  referensi   String?
  deskripsi   String?
  status      JournalStatus @default(DRAFT)
  createdById String?
  reversalOf  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       JournalLine[]
}

model JournalLine {
  id        String   @id @default(uuid())
  journalId String
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  debit     Decimal  @default(0) @db.Decimal(15, 2)
  kredit    Decimal  @default(0) @db.Decimal(15, 2)
  deskripsi String?
  createdAt DateTime @default(now())
}

model FiscalYear {
  id        String         @id @default(uuid())
  nama      String
  startDate DateTime
  endDate   DateTime
  status    FiscalStatus   @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  periods   FiscalPeriod[]
}

model FiscalPeriod {
  id           String       @id @default(uuid())
  fiscalYearId String
  fiscalYear   FiscalYear   @relation(fields: [fiscalYearId], references: [id])
  bulan        Int
  tahun        Int
  startDate    DateTime
  endDate      DateTime
  status       FiscalStatus @default(OPEN)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ==================== PAYROLL ====================

enum PayrollComponentType {
  BASIC
  ALLOWANCE
  DEDUCTION
  OVERTIME
}

enum PayrollPeriodStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
}

enum SlipStatus {
  DRAFT
  APPROVED
  PAID
}

model PayrollComponent {
  id        String               @id @default(uuid())
  nama      String
  tipe      PayrollComponentType
  formula   String               @default("")
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  lines     PayrollSlipLine[]
}

model PayrollPeriod {
  id        String              @id @default(uuid())
  bulan     Int
  tahun     Int
  status    PayrollPeriodStatus @default(DRAFT)
  note      String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  slips     PayrollSlip[]
  @@unique([bulan, tahun])
}

model PayrollSlip {
  id               String        @id @default(uuid())
  employeeId       String
  employee         Employee      @relation(fields: [employeeId], references: [id])
  periodId         String
  period           PayrollPeriod @relation(fields: [periodId], references: [id])
  gajiPokok        Decimal       @default(0) @db.Decimal(15, 2)
  totalTunjangan   Decimal       @default(0) @db.Decimal(15, 2)
  totalPotongan    Decimal       @default(0) @db.Decimal(15, 2)
  bpjsKesEmployee  Decimal       @default(0) @db.Decimal(15, 2)
  bpjsKesEmployer  Decimal       @default(0) @db.Decimal(15, 2)
  bpjsTKEmployee   Decimal       @default(0) @db.Decimal(15, 2)
  bpjsTKEmployer   Decimal       @default(0) @db.Decimal(15, 2)
  totalPPh21       Decimal       @default(0) @db.Decimal(15, 2)
  netSalary        Decimal       @default(0) @db.Decimal(15, 2)
  status           SlipStatus    @default(DRAFT)
  journalId        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lines            PayrollSlipLine[]
  @@unique([employeeId, periodId])
}

model PayrollSlipLine {
  id          String           @id @default(uuid())
  slipId      String
  slip        PayrollSlip      @relation(fields: [slipId], references: [id], onDelete: Cascade)
  componentId String?
  component   PayrollComponent? @relation(fields: [componentId], references: [id])
  amount      Decimal          @db.Decimal(15, 2)
  deskripsi   String
  createdAt   DateTime         @default(now())
}

model BPJSConfig {
  id                 String   @id @default(uuid())
  employeeId         String   @unique
  employee           Employee @relation(fields: [employeeId], references: [id])
  bpjsKesEmployee    Decimal  @default(1) @db.Decimal(5, 2)
  bpjsKesEmployer    Decimal  @default(4) @db.Decimal(5, 2)
  bpjsTKJHTEmployee  Decimal  @default(2) @db.Decimal(5, 2)
  bpjsTKJHTEmployer  Decimal  @default(3.7) @db.Decimal(5, 2)
  bpjsTKJKK          Decimal  @default(0.24) @db.Decimal(5, 2)
  bpjsTKJKM          Decimal  @default(0.3) @db.Decimal(5, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ==================== FIXED ASSET MANAGEMENT ====================

enum DepreciasiMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  SOLD
}

model FixedAsset {
  id                  String           @id @default(uuid())
  kode                String           @unique
  nama                String
  kategori            String
  tanggalPerolehan    DateTime
  nilaiPerolehan      Decimal          @db.Decimal(15, 2)
  nilaiResidu         Decimal          @default(0) @db.Decimal(15, 2)
  umurEkonomi         Int
  metodeDepresiasi    DepreciasiMethod @default(STRAIGHT_LINE)
  accountAssetId      String?
  accountDepreciasiId String?
  accountAkumDepId    String?
  branchId            String?
  status              AssetStatus      @default(ACTIVE)
  note                String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  depreciations       AssetDepreciation[]
}

model AssetDepreciation {
  id               String     @id @default(uuid())
  assetId          String
  asset            FixedAsset @relation(fields: [assetId], references: [id])
  bulan            Int
  tahun            Int
  bebanDepresiasi  Decimal    @db.Decimal(15, 2)
  akumDepresiasi   Decimal    @db.Decimal(15, 2)
  nilaiBuku        Decimal    @db.Decimal(15, 2)
  journalId        String?
  createdAt        DateTime   @default(now())
  @@unique([assetId, bulan, tahun])
}

// ==================== BUDGET ====================

enum BudgetStatus {
  DRAFT
  APPROVED
}

model Budget {
  id           String       @id @default(uuid())
  nama         String
  fiscalYearId String?
  departemenId String?
  status       BudgetStatus @default(DRAFT)
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lines        BudgetLine[]
}

model BudgetLine {
  id        String  @id @default(uuid())
  budgetId  String
  budget    Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId String
  bulan     Int
  amount    Decimal @db.Decimal(15, 2)
}

// ==================== COMPANY & BRANCH ====================

model Company {
  id              String   @id @default(uuid())
  nama            String
  npwp            String?
  alamat          String?
  logo            String?
  defaultCurrency String   @default("IDR")
  timezone        String   @default("Asia/Jakarta")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  branches        Branch[]
}

model Branch {
  id           String  @id @default(uuid())
  companyId    String
  company      Company @relation(fields: [companyId], references: [id])
  kode         String  @unique
  nama         String
  alamat       String?
  isHeadOffice Boolean @default(false)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== HELPDESK TEAM ====================
model HelpdeskTeam {
  id        String           @id @default(uuid())
  name      String
  active    Boolean          @default(true)
  slaHours  Int              @default(24)
  createdAt DateTime         @default(now())
  tickets   HelpdeskTicket[]
}

// ==================== WORK CENTER & WORK ORDER ====================
model WorkCenter {
  id         String      @id @default(uuid())
  code       String?     @unique
  name       String
  active     Boolean     @default(true)
  capacity   Int         @default(1)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workOrders WorkOrder[]
}

model WorkOrder {
  id           String       @id @default(uuid())
  moId         String
  mo           ManufacturingOrder @relation(fields: [moId], references: [id])
  workCenterId String?
  workCenter   WorkCenter?  @relation(fields: [workCenterId], references: [id])
  sequence     Int          @default(0)
  durationMin  Decimal      @default(0) @db.Decimal(10, 2)
  status       String       @default("draft")
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
}

// ==================== QUALITY ALERT ====================
model QualityAlert {
  id          String   @id @default(uuid())
  subject     String
  description String?
  stage       String   @default("new")
  priority    Int      @default(0)
  productId   String?
  assigneeId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TASK (PROJECT MANAGEMENT) ====================
model Task {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  parentId    String?
  parent      Task?     @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks    Task[]    @relation("TaskSubtasks")
  title       String
  description String?
  assignedTo  String?
  assigneeId  String?
  stage       String    @default("todo")
  status      String    @default("todo")
  priority    Int       @default(0)
  active      Boolean   @default(true)
  dueDate     DateTime?
  timesheets  Timesheet[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
